{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "projectName": "CppRTOS ",
    "configurations": [
            {
            "name": "STlink Debug",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}/build/Debug/TestRtos.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "stutil",
            "device": "STM32F765II",
            "interface": "swd",
            "runToEntryPoint": "main",
            "preLaunchTask": "Build all", // configured in tasks.json
            "svdFile": "C:/DevTools/cmsis/STMicroelectronics_CMSIS_SVD/STM32F765.svd", // Include svd to watch device peripherals
            "swoConfig": {} // currently (v1.7.0) not supported
        },
        {
            "name": "STlink Attach",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}/build/Debug/TestRtos.elf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "stutil",
            "device": "STM32F765II",
            "interface": "swd",
            "runToEntryPoint": "main", // will be ignored by attach mode
            "preLaunchTask": "Build all", // configured in tasks.json
            // "preLaunchCommands": ["Build all"], // you can execute command instead of task
            "svdFile": "", // Include svd to watch device peripherals
            "swoConfig": {} // currently (v1.7.0) not supported
        },
    ]
}